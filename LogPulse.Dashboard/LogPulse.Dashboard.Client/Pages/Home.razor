@page "/"
@using LogPulse.Core.Models
@inject HttpClient Http

<PageTitle>LogPulse Dashboard</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-primary">📋 Живи Логове (System Live Logs)</h1>
        <button class="btn btn-success" @onclick="LoadLogs">🔄 Обнови данните</button>
    </div>

    @if (logs == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Зареждане на логове от API-то...</p>
        </div>
    }
    else if (!logs.Any())
    {
        <div class="alert alert-warning">Няма намерени логове в базата данни.</div>
    }
    else
    {
        <table class="table table-striped table-hover border shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Време</th>
                    <th>Ниво</th>
                    <th>Източник</th>
                    <th>Машина</th>
                    <th>Съобщение</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in logs)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("HH:mm:ss dd.MM.yyyy")</td>
                        <td>
                            <span class="badge @(log.LogLevel == "ERROR" ? "bg-danger" : "bg-info")">
                                @log.LogLevel
                            </span>
                        </td>
                        <td>@log.Source</td>
                        <td>@log.MachineName</td>
                        <td><strong>@log.Message</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<LogEntry>? logs;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {   
        try
        {
            logs = await Http.GetFromJsonAsync<List<LogEntry>>("api/logs");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Грешка при комуникация с API: {ex.Message}");
            logs = new List<LogEntry>();
        }
    }
}